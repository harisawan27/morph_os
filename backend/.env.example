# Copy to .env and fill in values for local development

DATABASE_URL=postgresql://morph:morphpassword@localhost:5432/morph_db
GEMINI_API_KEY=your-gemini-api-key

# YouTube Data API v3 — enable at console.cloud.google.com → APIs & Services
YOUTUBE_API_KEY=your-youtube-data-api-key

# Must match the frontend NEXTAUTH_SECRET exactly
NEXTAUTH_SECRET=your-secret-at-least-32-chars

# Comma-separated list of allowed CORS origins (dev only — prod is same-origin)
ALLOWED_ORIGINS=http://localhost:3000
